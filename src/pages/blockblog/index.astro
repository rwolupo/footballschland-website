---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });

const categoryColors: Record<string, string> = {
  'Draft': 'bg-crimson/20 text-crimson border-crimson/40',
  'NFL': 'bg-blue-900/50 text-blue-400 border-blue-700',
  'College': 'bg-emerald-900/50 text-emerald-400 border-emerald-700',
};
---

<BaseLayout
  title="Blockblog | Footballschland"
  description="Der Blockblog ist unser Zuhause für Artikel über deutsche Talente im American Football. Von ausführlichen Draft-Analysen bis hin zu College-Saisonberichten."
>

<!-- Hero -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#111111] pt-28 pb-12 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <p class="section-label mb-4">Blockblog</p>
    <h1 class="font-display text-5xl md:text-7xl font-bold text-white mb-6 leading-tight">
      Alle Artikel
    </h1>
    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto font-body leading-relaxed">
      Der Blockblog ist unser Zuhause für Artikel über deutsche Talente im American Football. Von ausführlichen Draft-Analysen bis hin zu College-Saisonberichten.
    </p>
  </div>
</section>

<!-- Category Filter -->
<section class="py-6 px-4 bg-[#111111] border-b border-white/10">
  <div class="max-w-4xl mx-auto flex flex-wrap gap-2 justify-center">
    <a href="/blockblog" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-crimson/20 text-crimson border-crimson/40 hover:bg-crimson/30 transition-colors">
      Alle Beiträge
    </a>
    <a href="/blockblog/categories/draft" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-crimson/40 hover:text-white transition-colors">
      Draft
    </a>
    <a href="/blockblog/categories/nfl" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-blue-500/40 hover:text-white transition-colors">
      NFL
    </a>
    <a href="/blockblog/categories/college" class="px-4 py-1.5 text-xs font-bold uppercase tracking-widest rounded border bg-white/5 text-white/60 border-white/20 hover:border-emerald-500/40 hover:text-white transition-colors">
      College
    </a>
  </div>
</section>

<!-- Posts -->
<section class="py-16 px-4 bg-[#0D0D0D]">
  <div class="max-w-4xl mx-auto">
    {posts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-white/40 font-body text-lg">Keine Beiträge gefunden.</p>
      </div>
    ) : (
      <div class="flex flex-col gap-8">
        {posts.map((post) => {
          const badgeClass = categoryColors[post.data.category] || 'bg-white/10 text-white/60 border-white/20';
          return (
            <article class="group grid grid-cols-1 md:grid-cols-[2fr_3fr] bg-[#1A1A1A] border border-white/10 hover:border-crimson/50 rounded-xl overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-crimson/10">
              <a href={`/blockblog/${post.slug}`} class="block relative aspect-video md:aspect-auto bg-[#111111] overflow-hidden min-h-[200px]">
                <div class="w-full h-full bg-gradient-to-br from-crimson/20 to-[#0D0D0D] flex items-center justify-center">
                  <span class="font-display text-white/20 text-6xl font-bold">FS</span>
                </div>
              </a>
              <div class="flex flex-col p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class={`px-2 py-0.5 text-xs font-bold uppercase tracking-widest rounded border ${badgeClass}`}>
                    {post.data.category}
                  </span>
                  <span class="text-white/40 text-xs font-body">{formatDate(post.data.pubDate)}</span>
                  {post.data.readTime && (
                    <span class="text-white/40 text-xs font-body">· {post.data.readTime}</span>
                  )}
                </div>
                <a href={`/blockblog/${post.slug}`} class="flex-1">
                  <h2 class="font-display text-xl md:text-2xl font-bold text-white mb-3 leading-tight group-hover:text-crimson-light transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-white/60 text-sm leading-relaxed font-body">
                    {post.data.description}
                  </p>
                </a>
                <div class="mt-4 flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-crimson flex items-center justify-center text-white font-bold text-xs">DD</div>
                    <span class="text-white/40 text-xs font-body">{post.data.author}</span>
                  </div>
                  <a href={`/blockblog/${post.slug}`} class="text-crimson text-sm font-semibold flex items-center gap-1 hover:gap-2 transition-all">
                    Lesen <span>→</span>
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</section>

</BaseLayout>
