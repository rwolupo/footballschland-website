---
// blog/index.astro — Blog overview
import BaseLayout from '../../layouts/BaseLayout.astro';

// TODO: In Phase 2c, load these from Astro content collections
// const { data: posts } = await getCollection('blog');
// TODO: Sort by date and map properly

const posts = [
  {
    title: 'Deutsche Spieler im NFL Draft 2026: Sieben Deutsche wollen den Sprung in die NFL schaffen',
    slug: 'deutsche-spieler-im-nfl-draft-2026',
    excerpt: 'Der NFL Draft 2026 rückt näher – und mit ihm die Frage, die uns jedes Jahr aufs Neue elektrisiert: Wer wird der nächste Deutsche in der NFL? In diesem Jahr sind es gleich sieben Namen, die auf dem Radar der Scouts stehen.',
    date: '2026-03-21',
    readTime: '14 Min. Lesezeit',
    category: 'Draft',
    views: 76,
  },
  {
    title: 'Deutsche Talente im American Football - D1 Colleges Saison 2025',
    slug: 'deutsche-talente-d1-2025',
    excerpt: 'American Football boomt in Deutschland – und immer mehr Talente wagen den Sprung in die USA. 2025 stehen so viele Deutsche wie nie zuvor auf D1-Rosters.',
    date: '2025-09-05',
    readTime: '6 Min. Lesezeit',
    category: 'College',
    views: 535,
  },
];
---

<BaseLayout
  title="Blockblog | Footballschland"
  description="Der Blockblog ist unser Zuhause für Artikel über deutsche Talente im American Football. Von ausführlichen Draft-Analysen bis hin zu College-Saisonberichten."
>

<!-- Hero Section -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-32 pb-12 px-4">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="font-display text-6xl md:text-7xl font-bold text-white mb-6">
      Blockblog
    </h1>
    
    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto font-body">
      Der Blockblog ist unser Zuhause für Artikel über deutsche Talente im American Football. Von ausführlichen Draft-Analysen bis hin zu College-Saisonberichten – hier findest du unsere Texte.
    </p>
  </div>
</section>

<!-- Blog Posts Grid -->
<section class="py-20 px-4 bg-[#0D0D0D]">
  <div class="max-w-4xl mx-auto">
    <div class="space-y-8">
      {posts.map((post) => (
        <article class="group p-6 md:p-8 bg-white/5 border border-white/10 hover:border-crimson/50 rounded transition-all">
          <div class="flex items-start justify-between gap-4 mb-4">
            <p class="text-crimson text-xs font-semibold uppercase tracking-widest">
              {post.category}
            </p>
            <span class="text-white/40 text-xs whitespace-nowrap">
              {post.views} Views
            </span>
          </div>
          
          <h2 class="text-2xl md:text-3xl font-display font-bold text-white mb-4 group-hover:text-crimson transition-colors">
            {post.title}
          </h2>
          
          <p class="text-white/60 text-base leading-relaxed mb-6 font-body">
            {post.excerpt}
          </p>
          
          <div class="flex items-center justify-between text-sm text-white/40">
            <div class="space-x-4">
              <span>{new Date(post.date).toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              <span>•</span>
              <span>{post.readTime}</span>
            </div>
          </div>
          
          <a href={`/blog/${post.slug}`} class="mt-6 inline-flex items-center gap-2 text-crimson hover:text-crimson-light font-semibold transition-colors">
            Artikel lesen →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

</BaseLayout>
