---
// datenschutz.astro — Datenschutz / Privacy Policy
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Datenschutz | Footballschland"
  description="Datenschutzerklärung von Footballschland"
>

<!-- Hero Section -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-32 pb-12 px-4">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="font-display text-6xl md:text-7xl font-bold text-white mb-6">
      Datenschutz
    </h1>
  </div>
</section>

<!-- Content -->
<section class="py-20 px-4 bg-[#0D0D0D]">
  <div class="max-w-4xl mx-auto prose prose-invert">
    <p class="text-white/70 text-lg font-body">
      Der Datenschutztext wird vom Betreiber ergänzt.
    </p>
  </div>
</section>

</BaseLayout>
