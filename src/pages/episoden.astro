---
// episoden.astro — Podcast Episoden
import BaseLayout from '../layouts/BaseLayout.astro';

const podcastPlatforms = [
  { name: 'Spotify', url: 'https://open.spotify.com/show/1DlSNLB5HsxSp12nilwjbc', color: '#1DB954' },
  { name: 'Apple Podcasts', url: 'https://podcasts.apple.com/de/podcast/footballschland-american-football-made-in-germany/id1674301287', color: '#B150E2' },
  { name: 'Amazon Music', url: 'https://music.amazon.de/podcasts/30356913-e520-4ebe-aaf9-4ae2f8a260ea/footballschland-american-football-made-in-germany', color: '#00A8E0' },
  { name: 'RTL+', url: 'https://plus.rtl.de/podcast/footballschland-american-football-made-in-germany-qb6ejviehu3ee', color: '#E4002B' },
  { name: 'Castbox', url: 'https://castbox.fm/vh/6522348', color: '#F55B23' },
  { name: 'RSS Feed', url: 'https://feeds.megaphone.fm/footballschland', color: '#F26522' },
];
---

<BaseLayout
  title="Episoden | Footballschland Podcast"
  description="Der Podcast für alle, die den Traum deutscher Football-Talente begleiten wollen!"
>

<!-- Hero Section -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-32 pb-12 px-4">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="font-display text-6xl md:text-7xl font-bold text-white mb-6">
      Episoden
    </h1>
    
    <p class="text-lg md:text-xl text-white/70 max-w-3xl mx-auto font-body">
      Der Podcast für alle, die den Traum deutscher Football-Talente begleiten wollen!
    </p>
  </div>
</section>

<!-- Spotify Embed -->
<section class="py-16 px-4 bg-[#0D0D0D]">
  <div class="max-w-4xl mx-auto">
    <h2 class="section-label text-center mb-10">Spotify Player</h2>
    
    <div class="rounded-lg overflow-hidden shadow-lg">
      <iframe
        src="https://open.spotify.com/embed/show/1DlSNLB5HsxSp12nilwjbc"
        width="100%"
        height="232"
        frameborder="0"
        allowfullscreen=""
        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      ></iframe>
    </div>
  </div>
</section>

<!-- Podcast Platforms -->
<section class="py-16 px-4 bg-gradient-to-b from-[#0D0D0D] to-[#1A1A1A] border-t border-white/10">
  <div class="max-w-7xl mx-auto">
    <h2 class="section-label text-center mb-10">Überall verfügbar</h2>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {podcastPlatforms.map((platform) => (
        <a
          href={platform.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-center px-4 py-6 rounded border border-white/10 hover:border-white/30 bg-white/5 hover:bg-white/10 transition-all"
        >
          <span class="text-white/80 group-hover:text-white font-semibold text-sm text-center transition-colors">
            {platform.name}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- About Section -->
<section class="py-20 px-4 bg-[#0D0D0D] border-t border-white/10">
  <div class="max-w-4xl mx-auto">
    <h2 class="section-label text-center">Über den Podcast</h2>
    
    <h3 class="text-4xl md:text-5xl font-display font-bold text-white text-center mb-8">
      Die Geschichten deutscher Talente
    </h3>

    <p class="text-lg text-white/70 text-center leading-relaxed font-body">
      Der Podcast für alle, die den Traum deutscher Football-Talente begleiten wollen! von Sandra Janat & Daniel Düngel
    </p>
  </div>
</section>

</BaseLayout>
