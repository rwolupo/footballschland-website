---
// impressum.astro — Impressum (Legal)
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Impressum | Footballschland"
  description="Impressum und rechtliche Informationen von Footballschland"
>

<!-- Hero Section -->
<section class="bg-gradient-to-b from-[#1A1A1A] to-[#0D0D0D] pt-32 pb-12 px-4">
  <div class="max-w-7xl mx-auto text-center">
    <h1 class="font-display text-6xl md:text-7xl font-bold text-white mb-6">
      Impressum
    </h1>
  </div>
</section>

<!-- Content -->
<section class="py-20 px-4 bg-[#0D0D0D]">
  <div class="max-w-4xl mx-auto text-white/70 font-body space-y-6">
    <div>
      <h2 class="text-2xl font-display font-bold text-white mb-4">Angaben gemäß § 5 TMG</h2>
      
      <p class="mb-4">
        <strong>Name:</strong> [TODO: Name des Betreibers]
      </p>
      
      <p class="mb-4">
        <strong>Adresse:</strong> [TODO: Straße und Hausnummer]<br />
        [TODO: Postleitzahl und Ort]<br />
        [TODO: Land]
      </p>
    </div>

    <div>
      <h3 class="text-xl font-display font-bold text-white mb-4">Kontakt</h3>
      
      <p class="mb-4">
        <strong>E-Mail:</strong> [TODO: E-Mail-Adresse]<br />
        <strong>Telefon:</strong> [TODO: Telefonnummer]
      </p>
    </div>

    <div>
      <h3 class="text-xl font-display font-bold text-white mb-4">Verantwortlich für den Inhalt</h3>
      
      <p class="mb-4">
        [TODO: Name der verantwortlichen Person/Institution]
      </p>
    </div>
  </div>
</section>

</BaseLayout>
